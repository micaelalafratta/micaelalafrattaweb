---
import { getCollection } from 'astro:content';
import CallToAction from '../components/CallToAction.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import ExperiencePreview from '../components/ExperiencePreview.astro';
import Skills from '../components/Skills.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

const dataProjects = (await getCollection('dataProjects'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

const experiences = (await getCollection('experience'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Hello, my name is Micaela Lafratta"
					tagline="I bridge data and communication — turning insights into decisions that actually land."
					align="start"
				>
					<div class="roles">
						<Pill>Communications</Pill>
						<Pill>Data & AI Ethics</Pill>
						<Pill>Business Insights</Pill>
					</div>
				</Hero>

				<img
					alt="Micaela Lafratta smiling in cream jacket and blue shirt"
					width="480"
					height="620"
					src="/assets/web-micaela-header.png"
				/>
			</header>

			<Skills />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">

			<!-- SELECTED WORK -->
			<section id="work" class="section with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Selected Work</h3>
					<p>A selection of communications projects — from end-to-end campaign management to strategic storytelling.</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li>
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/work/">
						View All
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<!-- DATA PROJECTS -->
			<section id="data-projects" class="section with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Data Projects</h3>
					<p>Personal and academic projects exploring data analysis, visualization and technical problem-solving.</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							dataProjects.map((project) => (
								<li>
									<PortfolioPreview project={project} basePath="data-projects" />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/data-projects/">
						View All
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

			<!-- ABOUT -->
			<section id="about" class="section about-section">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>About Me</h3>
				</header>

				<div class="about-body">

					<div class="about-photo">
						<img
							src="/assets/at-work.jpg"
							alt="Micaela Lafratta facilitating a workshop with an audience"
							loading="lazy"
						/>
					</div>

					<div class="about-content">
						<div class="about-text stack gap-4">
							<p>
								I'm a Senior Communications Strategist with 8 years of experience working across international 
								cooperation, human rights and the European third sector — with a technical stack in data analysis 
								that shapes how I think, not just what I deliver.
							</p>
							<p>
								I work at the intersection of strategic communication, data analysis and AI ethics. 
								SQL, Python, BigQuery and Power BI aren't side skills — they're how I understand what's 
								really happening in an organisation, and how I make sure the right people act on it.
							</p>
							<p>
								Part of my work starts before the brief exists. Clients rarely know how to articulate what 
								they need — and that's fine. I listen beyond what's said, identify what actually needs to be 
								communicated, and build from there.
							</p>
							<p>
								I've trained 200+ people across 15+ countries, managed partner networks of 24+ international 
								organisations, and delivered EU compliance reporting across multiple funding programmes. 
								I work in English, French and Spanish.
							</p>
							<p>
								AI ethics isn't a buzzword for me — it's a design principle shaped by a background in human 
								rights and years of working in contexts where getting communication wrong has real consequences.
							</p>

							<div class="about-cta">
								<CallToAction href="/assets/Micaela_Lafratta_CV.pdf">
									Download CV
									<Icon icon="arrow-right" size="1.2em" />
								</CallToAction>
							</div>
						</div>

						<div class="about-skills stack gap-4">

							<div class="skill-group">
								<h4>Communications</h4>
								<div class="pill-group">
									<Pill>Storytelling</Pill>
									<Pill>Strategic Copywriting</Pill>
									<Pill>Content Strategy</Pill>
									<Pill>Press & Media Relations</Pill>
									<Pill>KPI Reporting</Pill>
									<Pill>EU Reporting</Pill>
								</div>
							</div>

							<div class="skill-group">
								<h4>Analytics & Data</h4>
								<div class="pill-group">
									<Pill>SQL</Pill>
									<Pill>Python</Pill>
									<Pill>BigQuery</Pill>
									<Pill>Power BI</Pill>
									<Pill>Tableau</Pill>
									<Pill>GA4</Pill>
								</div>
							</div>

							<div class="skill-group">
								<h4>AI & Ethics</h4>
								<div class="pill-group">
									<Pill>AI Ethics</Pill>
									<Pill>Data Literacy</Pill>
									<Pill>LLM for Market Research</Pill>
								</div>
							</div>

							<div class="skill-group">
								<h4>Strategy & Management</h4>
								<div class="pill-group">
									<Pill>Stakeholder Management</Pill>
									<Pill>Partner Coordination</Pill>
									<Pill>Project Management</Pill>
									<Pill>Training & Facilitation</Pill>
									<Pill>Client Management</Pill>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- EXPERIENCE -->
			<section id="experience" class="section with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Experience</h3>
					<p>Roles where I've led communications, coordinated European projects and contributed to organisational strategy.</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							experiences.map((entry) => (
								<li>
									<ExperiencePreview entry={entry} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/experience/">
						View All
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>

		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	/* ===================== HERO ===================== */
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
		border: 2px solid #48769e;
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			gap: 0.5rem;
			flex-wrap: wrap;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}

	/* ===================== SECTIONS ===================== */
	.section {
		display: grid;
		gap: 2rem;
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: #6b4a3a;
	}

	.section-header h3 {
		font-size: var(--text-2xl);
		color: #140a0b;
		font-family: var(--font-brand);
	}

	:global(.theme-dark) .section-header {
		color: #c4aaa0;
	}

	:global(.theme-dark) .section-header h3 {
		color: #f7f3e9;
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h3 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* ===================== ABOUT ===================== */
	.about-section {
		display: grid;
		gap: 2rem;
	}

	.about-body {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.about-photo {
		width: 100%;
		border-radius: 1.5rem;
		overflow: hidden;
		box-shadow: var(--shadow-md);
		border: 2px solid #48769e;
		max-height: 28rem;
	}

	.about-photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 30%;
		display: block;
	}

	.about-content {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.about-text p {
		font-size: var(--text-md);
		color: #6b4a3a;
		line-height: 1.75;
		max-width: 65ch;
	}

	:global(.theme-dark) .about-text p {
		color: #c4aaa0;
	}

	.about-cta {
		margin-top: 1rem;
	}

	.skill-group {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.skill-group h4 {
		font-size: var(--text-sm);
		font-family: var(--font-brand);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #48769e;
		font-weight: 600;
	}

	:global(.theme-dark) .skill-group h4 {
		color: #7ab0d4;
	}

	.pill-group {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	@media (min-width: 50em) {
		.about-section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas:
				'header header header header'
				'body body body body';
			gap: 5rem;
		}

		.about-section .section-header {
			grid-area: header;
			justify-self: flex-start;
			text-align: left;
			font-size: var(--text-lg);
		}

		.about-section .section-header h3 {
			font-size: var(--text-4xl);
		}

		.about-body {
			grid-area: body;
			gap: 3rem;
		}

		.about-photo {
			border-radius: 2rem;
			max-height: 32rem;
		}

		.about-content {
			display: grid;
			grid-template-columns: 3fr 2fr;
			gap: 4rem;
			align-items: start;
		}
	}
</style>
