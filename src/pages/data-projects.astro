---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('dataProjects')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
	title="Data Projects | Micaela Lafratta"
	description="Personal and academic data analysis projects by Micaela Lafratta"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Data Projects"
				tagline="Personal and academic projects exploring data analysis, visualization and technical problem-solving."
				align="start"
			/>
			<Grid variant="offset">
				{
					projects.map((project) => (
						<li>
							<PortfolioPreview project={project} basePath="data-projects" />
						</li>
					))
				}
			</Grid>
		</main>
		<ContactCTA />
	</div>
</BaseLayout>
