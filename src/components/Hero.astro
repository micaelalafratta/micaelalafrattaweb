---
interface Props {
	title: string;
	subtitle?: string;
	tagline?: string;
	align?: 'start' | 'center';
}

const { align = 'center', tagline, title, subtitle } = Astro.props;
---

<div class:list={['hero stack gap-4', align]}>
	<div class="stack gap-2">
		<h1 class="title">{title}</h1>
		{subtitle && <p class="subtitle">{subtitle}</p>}
		{tagline && <p class="tagline">{tagline}</p>}
	</div>
	<slot />
</div>

<style>
	.hero {
		font-size: var(--text-lg);
		text-align: center;
	}

	.title,
	.tagline,
	.subtitle {
		max-width: 37ch;
		margin-inline: auto;
	}

	.title {
		font-size: var(--text-2xl);
		font-family: var(--font-brand);
		color: #140a0b;
		word-break: break-word;
		overflow-wrap: anywhere;
		hyphens: auto;
	}

	.subtitle {
		font-size: var(--text-xl);
		font-family: var(--font-brand);
		font-weight: 600;
		color: var(--accent-regular);
	}

	.tagline {
		color: #6b4a3a;
		font-family: var(--font-body);
	}

	:global(.theme-dark) .title {
		color: #f7f3e9;
	}

	:global(.theme-dark) .subtitle {
		color: var(--accent-dark);
	}

	:global(.theme-dark) .tagline {
		color: #c4aaa0;
	}

	@media (min-width: 50em) {
		.hero {
			font-size: var(--text-xl);
		}

		.start {
			text-align: start;
		}

		.start .title,
		.start .tagline,
		.start .subtitle {
			margin-inline: unset;
		}

		.title {
			font-size: var(--text-5xl);
		}

		.subtitle {
			font-size: var(--text-2xl);
		}
	}
</style>
