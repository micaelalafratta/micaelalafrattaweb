---
import Icon from './Icon.astro';
import type { iconPaths } from './IconPaths';
import ThemeToggle from './ThemeToggle.astro';

const textLinks: { label: string; href: string }[] = [
	{ label: 'Home', href: '/' },
	{ label: 'Work', href: '/#work' },
	{ label: 'About', href: '/#about' },
];

const iconLinks: { label: string; href: string; icon: keyof typeof iconPaths }[] = [
	{ label: 'LinkedIn', href: 'https://www.linkedin.com/in/micaela-lafratta-ramos/', icon: 'linkedin-logo' },
	{ label: 'GitHub', href: 'https://github.com/micaelalafratta', icon: 'github-logo' },
];

// For anchor links we just check if we're on the home page
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === import.meta.env.BASE_URL;
---

<nav>
	<div class="menu-header">
		<a href="/" class="site-title">
			<Icon icon="terminal-window" color="#48769e" size="1.6em" />
			Micaela Lafratta
		</a>
		<menu-button>
			<template>
				<button class="menu-button" aria-expanded="false">
					<span class="sr-only">Menu</span>
					<Icon icon="list" color="#48769e" />
				</button>
			</template>
		</menu-button>
	</div>
	<noscript>
		<ul class="nav-items">
			{
				textLinks.map(({ label, href }) => (
					<li>
						<a class="link" href={href}>
							{label}
						</a>
					</li>
				))
			}
		</ul>
	</noscript>
	<noscript>
		<div class="menu-footer">
			<div class="socials">
				{
					iconLinks.map(({ href, icon, label }) => (
						<a href={href} class="social">
							<span class="sr-only">{label}</span>
							<Icon icon={icon} color="#48769e" />
						</a>
					))
				}
			</div>
		</div>
	</noscript>
	<div id="menu-content" hidden>
		<ul class="nav-items">
			{
				textLinks.map(({ label, href }) => (
					<li>
						<a class="link" href={href}>
							{label}
						</a>
					</li>
				))
			}
		</ul>
		<div class="menu-footer">
			<div class="socials">
				{
					iconLinks.map(({ href, icon, label }) => (
						<a href={href} class="social">
							<span class="sr-only">{label}</span>
							<Icon icon={icon} color="#48769e" />
						</a>
					))
				}
			</div>
			<div class="theme-toggle">
				<ThemeToggle />
			</div>
		</div>
	</div>
</nav>

<script>
	class MenuButton extends HTMLElement {
		constructor() {
			super();
			this.appendChild(this.querySelector('template')!.content.cloneNode(true));
			const btn = this.querySelector('button')!;
			const menu = document.getElementById('menu-content')!;
			menu.hidden = true;
			menu.classList.add('menu-content');

			const setExpanded = (expand: boolean) => {
				btn.setAttribute('aria-expanded', expand ? 'true' : 'false');
				menu.hidden = !expand;
			};

			btn.addEventListener('click', () => setExpanded(menu.hidden === true));

			// Close mobile menu when clicking an anchor link
			menu.querySelectorAll('a').forEach(link => {
				link.addEventListener('click', () => {
					if (window.innerWidth < 800) {
						setExpanded(false);
					}
				});
			});

			const handleViewports = (e: MediaQueryList | MediaQueryListEvent) => {
				setExpanded(e.matches);
				btn.hidden = e.matches;
			};
			const mediaQueries = window.matchMedia('(min-width: 50em)');
			handleViewports(mediaQueries);
			mediaQueries.addEventListener('change', handleViewports);
		}
	}
	customElements.define('menu-button', MenuButton);
</script>

<style>
	nav {
		z-index: 9999;
		position: sticky;
		top: 0;
		font-family: var(--font-brand);
		font-weight: 500;
		margin-bottom: 3.5rem;
		background-color: #f7f3e9;
		border-bottom: 1px solid #48769e;
		/* Subtle backdrop blur for a polished sticky effect */
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		background-color: rgba(247, 243, 233, 0.95);
	}

	:global(.theme-dark) nav {
		background-color: rgba(20, 10, 11, 0.95);
		border-bottom-color: #7ab0d4;
	}

	.menu-header {
		display: flex;
		justify-content: space-between;
		gap: 0.5rem;
		padding: 1.5rem;
	}

	.site-title {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		line-height: 1.1;
		color: #140a0b;
		text-decoration: none;
		font-family: var(--font-brand);
		font-weight: 600;
	}

	:global(.theme-dark) .site-title {
		color: #f7f3e9;
	}

	.menu-button {
		position: relative;
		display: flex;
		border: 1px solid #48769e;
		border-radius: 999rem;
		padding: 0.5rem;
		font-size: 1.5rem;
		color: #48769e;
		background: #f7f3e9;
		box-shadow: var(--shadow-md);
		cursor: pointer;
	}

	:global(.theme-dark) .menu-button {
		background: #1e1210;
		border-color: #7ab0d4;
		color: #7ab0d4;
	}

	.menu-button[aria-expanded='true'] {
		background: #48769e;
		color: #f7f3e9;
	}

	.menu-button[hidden] {
		display: none;
	}

	.menu-content {
		position: absolute;
		left: 0;
		right: 0;
	}

	.nav-items {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		font-size: var(--text-md);
		line-height: 1.2;
		list-style: none;
		padding: 2rem;
		background-color: #f7f3e9;
		border-bottom: 1px solid #48769e;
	}

	:global(.theme-dark) .nav-items {
		background-color: #140a0b;
		border-bottom-color: #7ab0d4;
	}

	.link {
		display: inline-block;
		color: #6b4a3a;
		text-decoration: none;
	}

	:global(.theme-dark) .link {
		color: #c4aaa0;
	}

	.link[aria-current] {
		color: #140a0b;
		font-weight: 600;
	}

	:global(.theme-dark) .link[aria-current] {
		color: #f7f3e9;
	}

	.menu-footer {
		--icon-size: var(--text-xl);
		--icon-padding: 0.5rem;

		display: flex;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 1.5rem 2rem 1.5rem 1.5rem;
		background-color: #f7f3e9;
		border-radius: 0 0 0.75rem 0.75rem;
		box-shadow: var(--shadow-lg);
	}

	:global(.theme-dark) .menu-footer {
		background-color: #140a0b;
	}

	.socials {
		display: flex;
		flex-wrap: wrap;
		gap: 0.625rem;
		font-size: var(--icon-size);
	}

	.social {
		display: flex;
		padding: var(--icon-padding);
		text-decoration: none;
		color: #48769e;
		transition: color var(--theme-transition);
	}

	.social:hover,
	.social:focus {
		color: #c5774a;
	}

	.theme-toggle {
		display: flex;
		align-items: center;
		height: calc(var(--icon-size) + 2 * var(--icon-padding));
	}

	@media (min-width: 50em) {
		nav {
			display: grid;
			grid-template-columns: 1fr auto 1fr;
			align-items: center;
			padding: 1rem 5rem;
			gap: 1rem;
			border-bottom: none;
			box-shadow: 0 1px 12px rgba(72, 118, 158, 0.10);
		}

		.menu-header {
			padding: 0;
		}

		.site-title {
			font-size: var(--text-lg);
		}

		.menu-content {
			display: contents;
		}

		.nav-items {
			position: relative;
			flex-direction: row;
			font-size: var(--text-sm);
			border-radius: 999rem;
			border: 1px solid #48769e;
			padding: 0.5rem 0.5625rem;
			background: #f7f3e9;
			box-shadow: var(--shadow-md);
		}

		:global(.theme-dark) .nav-items {
			background: #1e1210;
			border-color: #7ab0d4;
		}

		.link {
			padding: 0.5rem 1rem;
			border-radius: 999rem;
			transition:
				color var(--theme-transition),
				background-color var(--theme-transition);
		}

		.link:hover,
		.link:focus {
			color: #140a0b;
			background-color: rgba(72, 118, 158, 0.12);
		}

		:global(.theme-dark) .link:hover,
		:global(.theme-dark) .link:focus {
			color: #f7f3e9;
			background-color: rgba(72, 118, 158, 0.2);
		}

		.link[aria-current='page'] {
			color: #f7f3e9;
			background-color: #48769e;
		}

		.menu-footer {
			--icon-padding: 0.375rem;
			justify-self: flex-end;
			align-items: center;
			padding: 0;
			background-color: transparent;
			box-shadow: none;
		}

		.socials {
			display: none;
		}
	}

	@media (min-width: 60em) {
		.socials {
			display: flex;
			justify-content: flex-end;
			gap: 0;
		}
	}

	@media (forced-colors: active) {
		.link[aria-current='page'] {
			color: SelectedItem;
		}
	}
</style>
